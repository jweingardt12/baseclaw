{
  "name": "baseclaw",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build:ui": "node build-ui.js",
    "build:server": "tsc -p tsconfig.json",
    "build:preview": "vite build --config vite.preview.build.config.ts",
    "build:pages": "VITE_BASE=/BaseClaw/ VITE_PUBLIC_PREVIEW=true vite build --config vite.preview.build.config.ts && mv dist/preview/preview.html dist/preview/index.html",
    "build": "npm run build:ui && npm run build:preview && npm run build:server",
    "start": "node dist/main.js",
    "dev": "npx tsx main.ts",
    "preview": "vite --config vite.preview.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/geist": "^5.2.8",
    "@hugeicons/core-free-icons": "^3.1.1",
    "@hugeicons/react": "^1.1.5",
    "@modelcontextprotocol/ext-apps": "^1.1.2",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@plexui/ui": "^0.7.47",
    "express": "^5.1.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.3",
    "@tailwindcss/vite": "^4.1.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/preact": "^3.2.4",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.5.0",
    "clsx": "^2.1.1",
    "happy-dom": "^20.6.1",
    "preact": "^10.28.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "recharts": "^2.15.4",
    "tailwind-merge": "^3.4.1",
    "tailwindcss": "^4.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.3.0",
    "vite-plugin-singlefile": "^2.0.0",
    "vitest": "^4.0.18"
  }
}
